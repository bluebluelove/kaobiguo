MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=3225883689@qq.com
MAIL_PASS=jnagdeqjeukrdcai
MAIL_FROM=考必过 <3225883689@qq.com>

# 验证码有效期（分钟）
VERIFICATION_CODE_EXPIRE_MINUTES=5

# 每日新词上限（可选，默认 50）
DAILY_NEW_WORDS_LIMIT=50

# CORS（生产环境建议指定前端域名）
CORS_ORIGIN=*
